# Real Estate Voice Agent - Environment Configuration

# ============= Pipecat & Voice Configuration =============
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_STT_MODEL=nova-3-general

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_VOICE_ID=eva
SARVAM_MODEL=bulbul:v3

# ============= PostgreSQL / Supabase Configuration =============
# Connection details for Supabase PostgreSQL database
# Format: postgresql://postgres:password@host:port/database

DB_HOST=db.zchsplaygtakpdyyjets.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSL_MODE=require

# ============= RAG Configuration (Phase 4) =============
QDRANT_URL=https://<your-cluster>.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
